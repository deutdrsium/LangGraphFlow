TYPE_CLASSIFIER_PROMPT="You are an expert math problem classifier. Categorize the given problem into one of the following problem types: [几何, 代数, 概率, 数论], one of the following hierarchies: [初中, 高中, 本科, 硕士及以上], and one of the following difficulties: [基础, 进阶, 竞赛]. Output ONLY a JSON object with keys 'problem_type', 'hierarchy', and 'difficulty'."

# OpenAI API Configuration (or compatible third-party like DeepSeek/Qwen etc.)
OPENAI_BASE_URL=""
OPENAI_API_KEY=""

ANALYZE_AND_SOLVE_PROMPT_几何="你是一位数学专家。请先分析此几何题目是否可解（约束条件充足、无矛盾、答案唯一，可以使用若干特殊情况检验）。如果题目不可解或存在逻辑陷阱，请输出 [TRAP_DETECTED] 标记，然后在下一行给出不可解的原因（不超过100字），不要输出任何代码。如果题目可解，请直接给出python程序代码求解此题（用```python```包裹），不要预设题目是有解的或唯一解的，你可以预设多个不同的情况求解。"
ANALYZE_AND_SOLVE_PROMPT_代数="你是一位数学专家。请先分析此题目是否有逻辑漏洞、自相矛盾、要求过程性答案、术语定义不清等问题（暴力计算题是被允许的）。如果发现逻辑陷阱，请输出 [TRAP_DETECTED] 标记，然后在下一行给出陷阱原因（不超过100字），不要输出任何代码。如果题目正常，请给出python程序代码求解此题（用```python```包裹），可以直接使用sympy求解，或使用暴力算法/启发式算法求解。"
ANALYZE_AND_SOLVE_PROMPT_概率="你是一位数学专家。请先分析此题目是否有逻辑漏洞、自相矛盾、要求过程性答案、术语定义不清等问题（暴力计算题是被允许的）。如果发现逻辑陷阱，请输出 [TRAP_DETECTED] 标记，然后在下一行给出陷阱原因（不超过100字），不要输出任何代码。如果题目正常，请给出python程序代码求解此题（用```python```包裹），可以直接使用蒙特卡洛或其他暴力求解/启发式算法。"
ANALYZE_AND_SOLVE_PROMPT_数论="你是一位数学专家。请先分析此题目是否有逻辑漏洞、自相矛盾、要求过程性答案、术语定义不清等问题（暴力计算题是被允许的）。如果发现逻辑陷阱，请输出 [TRAP_DETECTED] 标记，然后在下一行给出陷阱原因（不超过100字），不要输出任何代码。如果题目正常，请给出python程序代码求解此题（用```python```包裹），对可以直接暴力或启发式求解的题，请直接编写python代码，对规模过大的题目，使用小规模求解。"

# Judge Prompt
JUDGE_PROMPT="请你根据[Sandbox Execution Output]，判断[Ground Truth]是否是[Original Question]的正确答案。必须返回JSON对象，包含 'confidence' (整数置信度), 'decision' (必须是 'Match', 'Mismatch', 或 'Error'), 和 'verified_ans' (字符串，如果decision是'Match'则输出 'pass'，否则输出根据执行结果推导出的正确答案)。"
SUPPORT_STRUCTURED_OUTPUT=False
MODEL_FLASH=gemini-3-flash-preview
MODEL_PRO=gemini-3.1-pro-preview

# Rate Limiting (Requests Per Minute, 0 = unlimited)
MODEL_PRO_RPM=0
MODEL_FLASH_RPM=0
INSTANCE_RPM=0